{
  "publisher": "HoutanRocky",
  "name": "terminal-copy-on-select",
  "displayName": "Terminal Copy On Select",
  "version": "0.1.2",
  "private": false,
  "packageManager": "pnpm@10.27.0",
  "description": "Automatically copy selected text from the VS Code integrated terminal to your clipboard.",
  "author": "Houtan Rocky <houtan.rocky@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/houtan-rocky/vscode-extension-terminalcopyonselect#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/houtan-rocky/vscode-extension-terminalcopyonselect"
  },
  "bugs": {
    "url": "https://github.com/houtan-rocky/vscode-extension-terminalcopyonselect/issues"
  },
  "keywords": [
    "terminal",
    "copy",
    "clipboard",
    "copy on select",
    "selection",
    "integrated terminal",
    "xterm",
    "productivity",
    "developer tools"
  ],
  "categories": [
    "Other"
  ],
  "galleryBanner": {
    "color": "#0D1117",
    "theme": "dark"
  },
  "preview": false,
  "qna": "marketplace",
  "main": "./dist/index.cjs",
  "icon": "res/icon.png",
  "files": [
    "LICENSE.md",
    "dist/*",
    "res/*"
  ],
  "engines": {
    "vscode": "^1.97.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [],
    "configuration": {
      "type": "object",
      "title": "Terminal Copy On Select",
      "properties": {}
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --external vscode",
    "dev": "nr build --watch --sourcemap",
    "prepare": "nr update",
    "update": "vscode-ext-gen --output src/generated/meta.ts && node scripts/clean-generated-meta.mjs",
    "lint": "eslint .",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "vscode:prepublish": "nr build",
    "release": "bumpp",
    "ext:package": "vsce package --no-dependencies",
    "ext:publish": "vsxpub --no-dependencies"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.7.3",
    "@antfu/ni": "^28.0.0",
    "@types/node": "^25.0.3",
    "@types/vscode": "^1.97.0",
    "@vscode/vsce": "^3.7.1",
    "bumpp": "^10.3.2",
    "eslint": "^9.39.2",
    "ovsx": "^0.10.7",
    "reactive-vscode": "^1.0.0-beta.2",
    "taze": "^19.9.2",
    "tsdown": "^0.19.0-beta.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vitest": "^4.0.16",
    "vscode-ext-gen": "^1.5.1",
    "vsxpub": "^0.1.2"
  }
}
