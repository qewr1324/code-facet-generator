{
	"name": "code-facet-generator",
	"displayName": "Code Facet Generator",
	"description": "🍃 Code Facet Generator - Dynamic facet-based code generator for multiple languages for 💠 VSCode. ",
	"version": "1.0.0",
	"private": false,
	"packageManager": "pnpm@11.11.0",
	"author": "GhurbeSABZI <naiad.arts.studio@gmail.com>",
	"icon": "media/facet-icon.png",
	"license": "MIT",
	"homepage": "https://github.com/qewr1324/code-facet-generator#readme",
	"repository": {
		"type": "git",
		"url": "https://github.com/qewr1324/code-facet-generator"
	},
	"bugs": {
		"url": "https://github.com/qewr1324/code-facet-generator/issues"
	},
	"engines": {
		"vscode": "^1.85.0"
	},
	"keywords": [
		"facet",
		"language facet",
		"file",
		"vscode extension",
		"developer tools"
	],
	"categories": [
		"Programming Languages",
		"Other"
	],
	"galleryBanner": {
		"color": "#0D1117",
		"theme": "dark"
	},
	"preview": false,
	"qna": "marketplace",
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./out/src/extension.js",
	"files": [
		"dist/*",
		"media/*.svg",
		"res/*.svg",
		"scripts/*.mjs",
		"src/*.ts",
		"test/*.ts",
		".gitignore",
		"eslint.config.mjs",
		"info.json",
		"LICENSE.md",
		"package.json",
		"pnpm-lock.yaml",
		"pnpm-workspace.yaml",
		"README.md",
		"taze.config.ts",
		"tsconfig.json",
		"tsdown.config.ts"
	],
	"contributes": {
		"commands": [
			{
				"command": "facetGenerator.openPanel",
				"title": "Code Facet: Open Generator Panel"
			},
			{
				"command": "facetGenerator.generateFromStatusBar",
				"title": "Code Facet: Generate from Status Bar"
			},
			{
				"command": "facetGenerator.reloadConfig",
				"title": "Code Facet: Reload Configuration"
			}
		],
		"views": {
			"facet-generator": [
				{
					"id": "facetGeneratorTree",
					"name": "Facet Generator"
				}
			]
		},
		"viewsContainers": {
			"activitybar": [
				{
					"id": "facet-generator",
					"title": "Facet Generator",
					"icon": "media/facet-icon.svg"
				}
			]
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"build": "tsdown src/index.ts --external vscode",
		"dev": "nr build --watch --sourcemap",
		"prepare": "nr update",
		"update": "vscode-ext-gen --output src/generated/meta.ts && node scripts/clean-generated-meta.mjs",
		"lint": "eslint .",
		"test": "vitest",
		"typecheck": "tsc --noEmit",
		"vscode:prepublish:nr": "nr build",
		"release": "bumpp",
		"ext:package": "vsce package --no-dependencies",
		"ext:publish": "vsxpub --no-dependencies"
	},
	"devDependencies": {
		"@types/vscode": "^1.85.0",
		"@types/node": "^20.0.0",
		"typescript": "^5.3.0",
		"@antfu/eslint-config": "^6.7.3",
		"@antfu/ni": "^28.0.0",
		"@vscode/vsce": "^3.7.1",
		"bumpp": "^10.3.2",
		"eslint": "^9.39.2",
		"ovsx": "^0.10.7",
		"reactive-vscode": "^1.0.0-beta.2",
		"taze": "^19.9.2",
		"tsdown": "^0.19.0-beta.3",
		"vite": "^7.3.0",
		"vitest": "^4.0.16",
		"vscode-ext-gen": "^1.5.1",
		"vsxpub": "^0.1.2"
	}
}
